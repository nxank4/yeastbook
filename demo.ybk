  "cells": [
    {
      "id": "cell-01-setup",
      "type": "code",
      "source": "",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✗ Install failed: bun add exited with code 1\n"
          ]
        }
      ],
      "executionCount": 27
    },
    {
      "id": "cell-02-load-model",
      "type": "code",
      "source": "// Cell 2: Load a simple sentiment model\nimport { pipeline } from \"@xenova/transformers\"\n\nconsole.log(\"Loading sentiment analysis model...\")\nconst classifier = await pipeline(\"sentiment-analysis\")\nconsole.log(\"Model loaded!\")\nclassifier",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Loading sentiment analysis model...\nNo model specified. Using default model: \"Xenova/distilbert-base-uncased-finetuned-sst-2-english\".\nModel loaded!\n"
          ]
        },
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[Function: closure]"
          },
          "metadata": {},
          "execution_count": 49,
          "richOutput": {
            "type": "text",
            "text": "[object Function]"
          }
        }
      ],
      "executionCount": 49
    },
    {
      "id": "cell-03-inference",
      "type": "code",
      "source": "// Cell 3: Run inference\nconst texts = [\n  \"I love yeastbook, it's amazing!\",\n  \"This notebook is terrible and broken.\",\n  \"The weather today is okay I guess.\",\n  \"Bun runtime is incredibly fast!\",\n]\n\nconst results = await classifier(texts)\nresults",
      "outputs": [],
      "executionCount": 50
    },
    {
      "id": "cell-04-table",
      "type": "code",
      "source": "// Cell 4: Visualize results as table\nconst tableData = texts.map((text, i) => ({\n  text: text.slice(0, 40) + \"...\",\n  label: results[i].label,\n  score: (results[i].score * 100).toFixed(1) + \"%\",\n}))\ntableData",
      "outputs": [],
      "executionCount": 51
    },
    {
      "id": "cell-05-chart",
      "type": "code",
      "source": "// Cell 5: Visualize as chart\nconst positive = results.filter(r => r.label === \"POSITIVE\").length\nconst negative = results.filter(r => r.label === \"NEGATIVE\").length\n\n;({\n  __type: \"chart\",\n  data: [positive, negative],\n  config: {\n    chartType: \"doughnut\",\n    label: \"Sentiment Distribution\",\n    title: \"Sentiment Analysis Results\",\n  }\n})",
      "outputs": [],
      "executionCount": 52
    },
    {
      "id": "cell-06-benchmark",
      "type": "code",
      "source": "// Cell 6: Benchmark inference speed\n%timeit -n5 await classifier([\"Yeastbook is fast!\"])",
      "outputs": [],
      "executionCount": 53
    },
    {
      "id": "cell-07-multilingual",
      "type": "code",
      "source": "// Cell 7: Test với tiếng Việt (multilingual model)\n%install @xenova/transformers\n\nconst multiClassifier = await pipeline(\n  \"text-classification\",\n  \"Xenova/bert-base-multilingual-uncased-sentiment\"\n)\n\nconst vnTexts = [\n  \"Tôi rất thích dùng yeastbook\",\n  \"Notebook này bị lỗi quá nhiều\",\n  \"Bun runtime chạy rất nhanh\",\n]\n\nconst vnResults = await multiClassifier(vnTexts)\nvnResults.map((r, i) => ({\n  text: vnTexts[i],\n  stars: r.label,\n  confidence: (r.score * 100).toFixed(1) + \"%\"\n}))",
      "outputs": [],
      "executionCount": 55
    },
    {
      "id": "cell-08-ner",
      "type": "code",
      "source": "// Cell 8: Token classification (NER)\nconst ner = await pipeline(\"token-classification\", \"Xenova/bert-base-NER\")\n\nconst sentence = \"Anthropic built Claude and acquired Bun runtime for TypeScript development.\"\nconst entities = await ner(sentence)\n\nentities\n  .filter(e => e.score > 0.8)\n  .map(e => ({\n    word: e.word,\n    entity: e.entity,\n    score: (e.score * 100).toFixed(1) + \"%\"\n  }))",
      "outputs": [],
      "executionCount": 54
    },
    {
      "id": "cell-09-embeddings",
      "type": "code",
      "source": "// Cell 9: Embeddings + cosine similarity\nconst embedder = await pipeline(\"feature-extraction\", \"Xenova/all-MiniLM-L6-v2\")\n\nconst sentences = [\n  \"Yeastbook is a TypeScript notebook\",\n  \"A notebook for writing code in TypeScript\",\n  \"I like eating bread for breakfast\",\n]\n\nconst embeddings = await embedder(sentences, { pooling: \"mean\", normalize: true })\n\n// Cosine similarity\nfunction cosineSim(a: number[], b: number[]): number {\n  const dot = a.reduce((sum, v, i) => sum + v * b[i], 0)\n  const normA = Math.sqrt(a.reduce((s, v) => s + v * v, 0))\n  const normB = Math.sqrt(b.reduce((s, v) => s + v * v, 0))\n  return dot / (normA * normB)\n}\n\nconst e = embeddings.tolist()\nconsole.log(\"Similarity [0] vs [1]:\", cosineSim(e[0], e[1]).toFixed(4))\nconsole.log(\"Similarity [0] vs [2]:\", cosineSim(e[0], e[2]).toFixed(4))\nconsole.log(\"→ Sentences 0 and 1 should be more similar\")",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Similarity [0] vs [1]: 0.6104\nSimilarity [0] vs [2]: 0.2397\n→ Sentences 0 and 1 should be more similar\n"
          ]
        }
      ],
      "executionCount": 57
    },
    {
      "id": "cell-10-memory",
      "type": "code",
      "source": "// Cell 10: Memory usage summary\nconst { heapUsed, heapTotal } = process.memoryUsage()\nconsole.log(`Heap used:  ${(heapUsed / 1024 / 1024).toFixed(1)} MB`)\nconsole.log(`Heap total: ${(heapTotal / 1024 / 1024).toFixed(1)} MB`)\nconsole.log(`Bun version: ${Bun.version}`)",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Heap used:  28.0 MB\nHeap total: 7.5 MB\nBun version: 1.3.11\n"
          ]
        }
      ],
      "executionCount": 57
    }
  ]
}
