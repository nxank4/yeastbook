  "cells": [
    {
      "id": "demo-header",
      "type": "markdown",
      "source": "# Yeastbook Demo\nA tour of features — run each cell with Shift+Enter"
    },
    {
      "id": "demo-01-basic",
      "type": "code",
      "source": "const greeting = \"Hello from Yeastbook \\ud83c\\udf5e\"\nconst version = Bun.version\nconsole.log(greeting)\nconsole.log(\"Bun version:\", version)",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Hello from Yeastbook 🍞\nBun version: 1.3.11\n"
          ]
        }
      ],
      "executionCount": 11
    },
    {
      "id": "demo-02-context",
      "type": "code",
      "source": "// Variable greeting from cell 1 persists\ngreeting + \" \\u2014 context works!\"",
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "\"Hello from Yeastbook 🍞 — context works!\""
          },
          "metadata": {},
          "execution_count": 12,
          "richOutput": {
            "type": "text",
            "text": "Hello from Yeastbook 🍞 — context works!"
          }
        }
      ],
      "executionCount": 12
    },
    {
      "id": "demo-03-await",
      "type": "code",
      "source": "const res = await fetch(\"https://jsonplaceholder.typicode.com/todos/1\")\nconst todo = await res.json()\ntodo",
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "{\n  userId: 1,\n  id: 1,\n  title: \"delectus aut autem\",\n  completed: false,\n}"
          },
          "metadata": {},
          "execution_count": 13,
          "richOutput": {
            "type": "json",
            "data": {
              "userId": 1,
              "id": 1,
              "title": "delectus aut autem",
              "completed": false
            }
          }
        }
      ],
      "executionCount": 13
    },
    {
      "id": "demo-04-table",
      "type": "code",
      "source": "const users = [\n  { name: \"Alice\", age: 30, role: \"admin\" },\n  { name: \"Bob\", age: 25, role: \"user\" },\n  { name: \"Charlie\", age: 35, role: \"user\" },\n]\nusers",
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[\n  {\n    name: \"Alice\",\n    age: 30,\n    role: \"admin\",\n  }, {\n    name: \"Bob\",\n    age: 25,\n    role: \"user\",\n  }, {\n    name: \"Charlie\",\n    age: 35,\n    role: \"user\",\n  }\n]"
          },
          "metadata": {},
          "execution_count": 14,
          "richOutput": {
            "type": "table",
            "rows": [
              {
                "name": "Alice",
                "age": 30,
                "role": "admin"
              },
              {
                "name": "Bob",
                "age": 25,
                "role": "user"
              },
              {
                "name": "Charlie",
                "age": 35,
                "role": "user"
              }
            ]
          }
        }
      ],
      "executionCount": 14
    },
    {
      "id": "demo-05-chart",
      "type": "code",
      "source": "({\n  __type: \"chart\",\n  data: [12, 19, 8, 15, 22, 18, 25],\n  config: {\n    chartType: \"line\",\n    label: \"Weekly activity\",\n    title: \"User Activity Q1\"\n  }\n})",
      "outputs": [],
      "executionCount": 15
    },
