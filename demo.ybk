    {
      "id": "demo-11-perf",
      "type": "code",
      "source": "const start = performance.now()\nlet sum = 0\nfor (let i = 0; i < 10_000_000; i++) sum += i\nconst end = performance.now()\nconsole.log(`10M iterations: ${(end - start).toFixed(2)}ms`)\nconsole.log(`Sum: ${sum}`)",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "10M iterations: 18.36ms\nSum: 49999995000000\n"
          ]
        }
      ],
      "executionCount": 11
    },
