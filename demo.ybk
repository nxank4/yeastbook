      "source": "// Cell 2: Verify lodash works + check version\r\nimport _ from \"lodash\"\r\nconst version = (await Bun.file(\"node_modules/lodash/package.json\").json()).version\r\nconsole.log(\"lodash version:\", version)\r\n_.chunk([1,2,3,4,5,6], 2)",
