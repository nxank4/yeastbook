    {
      "id": "lr-06-evaluate",
      "type": "code",
      "source": "// Cell 6: Evaluate on training data\nconst yPred = model.predict(X_norm)\nconst mse = model.mse(y, yPred)\nconst rmse = Math.sqrt(mse)\nconst mae = y.reduce((sum, yi, i) => sum + Math.abs(yi - yPred[i]!), 0) / y.length\n\nconst yMean = y.reduce((a, b) => a + b) / y.length\nconst ssTot = y.reduce((sum, yi) => sum + Math.pow(yi - yMean, 2), 0)\nconst ssRes = y.reduce((sum, yi, i) => sum + Math.pow(yi - yPred[i]!, 2), 0)\nconst r2 = 1 - ssRes / ssTot\n\nconsole.log(\"=== Model Performance ===\")\nconsole.log(`RMSE: $${Math.round(rmse).toLocaleString()}`)\nconsole.log(`MAE:  $${Math.round(mae).toLocaleString()}`)\nconsole.log(`R²:   ${r2.toFixed(4)} (${(r2 * 100).toFixed(1)}% variance explained)`)\nconsole.log(\"\\nModel weights:\", model.weights.map(w => w.toFixed(2)))\nconsole.log(\"Bias:\", model.bias.toFixed(0))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "=== Model Performance ===\nRMSE: $10,386\nMAE:  $9,429\nR²:   0.9936 (99.4% variance explained)\n\nModel weights: [ \"105609.49\", \"24549.82\", \"675.38\" ]\nBias: 340000\n"
          ]
        }
      ],
      "executionCount": 10
    },
    {
      "id": "lr-07-compare",
      "type": "code",
      "source": "// Cell 7: Compare predictions vs actual\nconst comparison = dataset.X.map((x, i) => ({\n  features: { sqft: x[0], beds: x[1], age: x[2] },\n  actual: `$${dataset.y[i]!.toLocaleString()}`,\n  predicted: `$${Math.round(yPred[i]!).toLocaleString()}`,\n  error: `${(((yPred[i]! - dataset.y[i]!) / dataset.y[i]!) * 100).toFixed(1)}%`\n}))\ncomparison",
      "outputs": [],
      "executionCount": 11
    },
    {
      "id": "lr-08-predict",
      "type": "code",
      "source": "// Cell 8: Predict on new houses\nfunction predictPrice(\n  sqft: number,\n  bedrooms: number,\n  ageYears: number\n): number {\n  const input = [[\n    (sqft - mean[0]!) / std[0]!,\n    (bedrooms - mean[1]!) / std[1]!,\n    (ageYears - mean[2]!) / std[2]!,\n  ]]\n  return Math.round(model.predict(input)[0]!)\n}\n\nconst newHouses = [\n  { sqft: 1700, beds: 3, age: 7 },\n  { sqft: 3000, beds: 5, age: 1 },\n  { sqft: 700, beds: 1, age: 30 },\n]\n\nnewHouses.map(h => ({\n  ...h,\n  predictedPrice: `$${predictPrice(h.sqft, h.beds, h.age).toLocaleString()}`\n}))",
      "outputs": [],
      "executionCount": 12
    },
    {
      "id": "lr-09-nn-header",
      "type": "markdown",
      "source": "## Bonus: Neural Network from Scratch\nA simple 2-layer neural net (3 → 8 → 1) with ReLU activation, trained on the same data."
    },
    {
      "id": "lr-10-nn",
      "type": "code",
      "source": "// Cell 9: Neural Network from scratch (2 layers)\nclass NeuralNet {\n  W1: number[][]\n  b1: number[]\n  W2: number[]\n  b2: number\n  losses: number[]\n\n  constructor(inputSize: number, hiddenSize: number) {\n    const scale1 = Math.sqrt(2 / inputSize)\n    const scale2 = Math.sqrt(2 / hiddenSize)\n    \n    this.W1 = Array(hiddenSize).fill(0).map(() =>\n      Array(inputSize).fill(0).map(() => (Math.random() - 0.5) * scale1)\n    )\n    this.b1 = Array(hiddenSize).fill(0)\n    this.W2 = Array(hiddenSize).fill(0).map(() => (Math.random() - 0.5) * scale2)\n    this.b2 = 0\n    this.losses = []\n  }\n\n  relu(x: number): number { return Math.max(0, x) }\n  reluDeriv(x: number): number { return x > 0 ? 1 : 0 }\n\n  forward(x: number[]): { h: number[], out: number } {\n    const h = this.W1.map((w, i) =>\n      this.relu(w.reduce((s, wj, j) => s + wj * x[j]!, 0) + this.b1[i]!)\n    )\n    const out = this.W2.reduce((s, w, i) => s + w * h[i]!, 0) + this.b2\n    return { h, out }\n  }\n\n  train(X: number[][], y: number[], epochs: number, lr = 0.01): void {\n    for (let epoch = 0; epoch < epochs; epoch++) {\n      let totalLoss = 0\n\n      for (let i = 0; i < X.length; i++) {\n        const { h, out } = this.forward(X[i]!)\n        const err = out - y[i]!\n        totalLoss += err * err\n\n        const dOut = err\n        const dW2 = h.map(hi => dOut * hi)\n        const db2 = dOut\n\n        const dH = this.W2.map(w => dOut * w)\n        const dW1 = this.W1.map((w, j) =>\n          w.map((_, k) => dH[j]! * this.reluDeriv(\n            w.reduce((s, wk, kk) => s + wk * X[i]![kk]!, 0) + this.b1[j]!\n          ) * X[i]![k]!)\n        )\n\n        this.W2 = this.W2.map((w, j) => w - lr * dW2[j]!)\n        this.b2 -= lr * db2\n        this.W1 = this.W1.map((w, j) =>\n          w.map((wk, k) => wk - lr * dW1[j]![k]!)\n        )\n        this.b1 = this.b1.map((b, j) =>\n          b - lr * dH[j]! * this.reluDeriv(\n            this.W1[j]!.reduce((s, w, k) => s + w * X[i]![k]!, 0) + b\n          )\n        )\n      }\n\n      if (epoch % 200 === 0) {\n        this.losses.push(totalLoss / X.length)\n      }\n    }\n  }\n}\n\nconst nn = new NeuralNet(3, 8)\nconsole.log(\"Neural net initialized: 3 → 8 → 1\")\nnn.train(X_norm, y.map(v => v / 1e6), 1000, lr = 0.001)\n\nconst nnPred = X_norm.map(x => Math.round(nn.forward(x).out * 1e6))\nconst nnRmse = Math.sqrt(\n  y.reduce((s, yi, i) => s + Math.pow(yi - nnPred[i]!, 2), 0) / y.length\n)\n\nconsole.log(`Neural Net RMSE: $${Math.round(nnRmse).toLocaleString()}`)\nconsole.log(`Linear Model RMSE: $${Math.round(Math.sqrt(model.mse(y, yPred))).toLocaleString()}`)",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Neural net initialized: 3 → 8 → 1\nNeural Net RMSE: $27,721\nLinear Model RMSE: $10,386\n"
          ]
        }
      ],
      "executionCount": 13
    },
    {
      "id": "lr-11-chart",
      "type": "code",
      "source": "// Cell 10: Model comparison chart\n;({\n  __type: \"chart\",\n  data: [Math.sqrt(model.mse(y, yPred)), Math.sqrt(\n    y.reduce((s, yi, i) => s + Math.pow(yi - X_norm.map(x =>\n      Math.round(nn.forward(x).out * 1e6))[i]!, 2), 0) / y.length\n  )],\n  config: {\n    chartType: \"bar\",\n    label: \"RMSE (USD)\",\n    title: \"Linear Regression vs Neural Network\",\n  }\n})",
      "outputs": [
