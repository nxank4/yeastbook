  "cells": [
    {
      "id": "lr-header",
      "type": "markdown",
      "source": "# Linear Regression from Scratch\nTraining a linear regression model in pure TypeScript — no libraries needed.\n\nPredicts house prices from: square footage, bedrooms, and age."
    },
    {
      "id": "lr-01-dataset",
      "type": "code",
      "source": "// Cell 1: Setup dataset — predict house prices\nconst dataset = {\n  // [size_sqft, bedrooms, age_years] → price_usd\n  X: [\n    [1200, 2, 10], [1500, 3, 5], [900, 1, 20],\n    [2000, 4, 2], [1800, 3, 8], [1100, 2, 15],\n    [2500, 5, 1], [1300, 2, 12], [1600, 3, 6],\n    [800, 1, 25], [2200, 4, 3], [1400, 2, 9],\n  ],\n  y: [\n    250000, 350000, 180000, 480000, 420000, 220000,\n    580000, 270000, 370000, 160000, 510000, 290000,\n  ]\n}\n\nconsole.log(\"Dataset size:\", dataset.X.length, \"samples\")\nconsole.log(\"Features: size_sqft, bedrooms, age_years\")\nconsole.log(\"Target: price_usd\")\ndataset.X.slice(0, 3).map((x, i) => ({\n  features: x,\n  price: dataset.y[i]\n}))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset size: 12 samples\nFeatures: size_sqft, bedrooms, age_years\nTarget: price_usd\n"
          ]
        }
      ],
      "executionCount": 5
    },
    {
      "id": "lr-02-normalize",
      "type": "code",
      "source": "// Cell 2: Normalize features (important for gradient descent)\nfunction normalize(X: number[][]): { \n  normalized: number[][], \n  mean: number[], \n  std: number[] \n} {\n  const numFeatures = X[0]!.length\n  const mean = Array(numFeatures).fill(0) as number[]\n  const std = Array(numFeatures).fill(0) as number[]\n  \n  // Compute mean\n  for (const row of X) {\n    for (let j = 0; j < numFeatures; j++) {\n      mean[j]! += row[j]! / X.length\n    }\n  }\n  \n  // Compute std\n  for (const row of X) {\n    for (let j = 0; j < numFeatures; j++) {\n      std[j]! += Math.pow(row[j]! - mean[j]!, 2) / X.length\n    }\n  }\n  for (let j = 0; j < numFeatures; j++) {\n    std[j] = Math.sqrt(std[j]!)\n  }\n  \n  // Normalize\n  const normalized = X.map(row =>\n    row.map((val, j) => (val - mean[j]!) / (std[j]! || 1))\n  )\n  \n  return { normalized, mean, std }\n}\n\nconst { normalized: X_norm, mean, std } = normalize(dataset.X)\nconst y = dataset.y\n\nconsole.log(\"Feature means:\", mean.map(v => v.toFixed(1)))\nconsole.log(\"Feature stds:\", std.map(v => v.toFixed(1)))\nconsole.log(\"Sample normalized:\", X_norm[0]!.map(v => v.toFixed(3)))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Feature means: [ \"1525.0\", \"2.7\", \"9.7\" ]\nFeature stds: [ \"498.5\", \"1.2\", \"7.0\" ]\nSample normalized: [ \"-0.652\", \"-0.566\", \"0.047\" ]\n"
          ]
        }
      ],
      "executionCount": 6
    },
    {
      "id": "lr-03-model",
      "type": "code",
      "source": "// Cell 3: Linear Regression model\nclass LinearRegression {\n  weights: number[]\n  bias: number\n  learningRate: number\n  losses: number[]\n  \n  constructor(numFeatures: number, learningRate = 0.01) {\n    this.weights = Array(numFeatures).fill(0).map(() => \n      (Math.random() - 0.5) * 0.01\n    )\n    this.bias = 0\n    this.learningRate = learningRate\n    this.losses = []\n  }\n  \n  predict(X: number[][]): number[] {\n    return X.map(row => \n      row.reduce((sum, val, i) => sum + val * this.weights[i]!, 0) + this.bias\n    )\n  }\n  \n  mse(yTrue: number[], yPred: number[]): number {\n    return yTrue.reduce((sum, y, i) => \n      sum + Math.pow(y - yPred[i]!, 2), 0\n    ) / yTrue.length\n  }\n  \n  train(X: number[][], y: number[], epochs: number): void {\n    const n = X.length\n    \n    for (let epoch = 0; epoch < epochs; epoch++) {\n      const yPred = this.predict(X)\n      \n      const errors = yPred.map((p, i) => p - y[i]!)\n      const dW = this.weights.map((_, j) =>\n        errors.reduce((sum, err, i) => sum + err * X[i]![j]!, 0) / n\n      )\n      const dB = errors.reduce((sum, err) => sum + err, 0) / n\n      \n      this.weights = this.weights.map((w, j) => w - this.learningRate * dW[j]!)\n      this.bias -= this.learningRate * dB\n      \n      if (epoch % 100 === 0) {\n        const loss = this.mse(y, this.predict(X))\n        this.losses.push(loss)\n      }\n    }\n  }\n}\n\nconst model = new LinearRegression(3, learningRate = 0.1)\nconsole.log(\"Model initialized\")\nconsole.log(\"Initial weights:\", model.weights.map(w => w.toFixed(4)))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Model initialized\nInitial weights: [ \"-0.0032\", \"-0.0050\", \"-0.0022\" ]\n"
          ]
        }
      ],
      "executionCount": 7
    },
    {
      "id": "lr-04-train",
      "type": "code",
      "source": "// Cell 4: Train the model\nconsole.log(\"Training started...\")\nconst startTime = performance.now()\n\nmodel.train(X_norm, y, epochs = 2000)\n\nconst trainTime = performance.now() - startTime\nconsole.log(`Training done in ${trainTime.toFixed(1)}ms`)\n\nconst lossCurve = model.losses.map((loss, i) => ({\n  epoch: i * 100,\n  loss: Math.round(loss),\n  rmse: Math.round(Math.sqrt(loss))\n}))\n\nconsole.log(\"\\nLoss curve (every 100 epochs):\")\nlossCurve.forEach(l => console.log(`  Epoch ${l.epoch}: RMSE=$${l.rmse.toLocaleString()}`))",
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Training started...\nTraining done in 5.1ms\n\nLoss curve (every 100 epochs):\n  Epoch 0: RMSE=$320,117\n  Epoch 100: RMSE=$13,408\n  Epoch 200: RMSE=$11,686\n  Epoch 300: RMSE=$11,194\n  Epoch 400: RMSE=$10,922\n  Epoch 500: RMSE=$10,743\n  Epoch 600: RMSE=$10,623\n  Epoch 700: RMSE=$10,544\n  Epoch 800: RMSE=$10,491\n  Epoch 900: RMSE=$10,455\n  Epoch 1000: RMSE=$10,432\n  Epoch 1100: RMSE=$10,416\n  Epoch 1200: RMSE=$10,406\n  Epoch 1300: RMSE=$10,399\n  Epoch 1400: RMSE=$10,395\n  Epoch 1500: RMSE=$10,392\n  Epoch 1600: RMSE=$10,390\n  Epoch 1700: RMSE=$10,388\n  Epoch 1800: RMSE=$10,387\n  Epoch 1900: RMSE=$10,387\n"
          ]
        }
      ],
      "executionCount": 8
    },
    {
      "id": "lr-05-chart",
      "type": "code",
      "source": "// Cell 5: Visualize training loss as chart\n;({\n  __type: \"chart\",\n  data: model.losses.map(l => Math.sqrt(l)),\n  config: {\n    chartType: \"line\",\n    label: \"RMSE (USD)\",\n    title: \"Training Loss Over Time\",\n  }\n})",
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": "[\n  320117.0292655496, 13407.839352231284, 11686.469451970255, 11194.459226839523,\n  10921.82835403806, 10743.023465961574, 10623.489747245643, 10543.67757934982, 10490.529249016241,\n  10455.20883078125, 10431.769006917384, 10416.228170505266, 10405.93090789705, 10399.11085438788,\n  10394.595068913379, 10391.60556648173, 10389.626722496845, 10388.31697036813, 10387.45012140099,\n  10386.876424668746\n]"
          },
          "metadata": {},
