{
  "name": "yeastbook-monorepo",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run dev:ui & bun run dev:server",
    "dev:server": "bun --watch packages/app/src/cli.ts new --dev --dir demos",
    "dev:ui": "mkdir -p packages/ui/dist && cp packages/ui/src/index.html packages/ui/dist/index.html && bun build packages/ui/src/index.tsx --outdir packages/ui/dist --bundle --watch",
    "build:ui": "bun run --filter @yeastbook/ui build",
    "build:embed": "bun run scripts/embed-assets.ts",
    "build:all": "bun run build:ui && bun run build:embed && bun run build:binary:linux",
    "build:binary:linux": "bun build --compile --target=bun-linux-x64 packages/app/src/cli.ts --outfile binaries/yeastbook-linux",
    "build:binary:mac": "bun build --compile --target=bun-macos-arm64 packages/app/src/cli.ts --outfile binaries/yeastbook-macos",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dayjs": "^1.11.20",
    "lodash": "^4.17.23"
  }
}
